# Adicionar este bloco ao Caddyfile do PyCatalog em /opt/pycatalog/Caddyfile
# e redeployar o PyCatalog para aplicar.

{$TERMO_DOMAIN} {
    # WebSocket (socket.io) → game server
    handle /socket.io/* {
        reverse_proxy termo-server:3001
    }

    # React SPA estático
    handle {
        reverse_proxy termo-frontend:80
    }
}

www.{$TERMO_DOMAIN} {
    redir https://{$TERMO_DOMAIN}{uri} permanent
}
