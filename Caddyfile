# Este Caddyfile NÃO é usado diretamente pelo termo.
# As rotas abaixo estão no Caddyfile do PyCatalog (/opt/pycatalog/Caddyfile),
# que é o único Caddy rodando na VPS.

multitermo.vitreon.tech {
    handle /share* {
        reverse_proxy termo-server:3001
    }
    handle /room/* {
        reverse_proxy termo-server:3001
    }
    handle /health {
        reverse_proxy termo-server:3001
    }
    handle /socket.io/* {
        reverse_proxy termo-server:3001
    }
    handle {
        reverse_proxy termo-frontend:80
    }
}
